; Engine configuration file.
; Godot 4.5.2-stable — ShowdownBot Studio Viewer v0 (Plan B)

config_version=5

[application]

config/name="ShowdownBot Studio"
config/description="Viewer v0 local bundle shell (Plan B)"
config/features=PackedStringArray("4.5")
config/icon="res://icon.svg"
run/main_scene="res://src/workspace/app_shell.tscn"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[gdunit4]

settings/common/update_notification_enabled=false

[rendering]

renderer/rendering_method="gl_compatibility"
