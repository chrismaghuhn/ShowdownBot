# Reranker model artifacts are consumed raw by LightGBM / JSON parsers.
# They must never have their line endings rewritten on checkout (core.autocrlf),
# or LightGBM's Booster(model_file=...) aborts with "expect a tree here".
models/reranker/** -text

# Server patches are consumed by `git apply` against an LF-normalized clone.
# CRLF rewriting on checkout would make the patch fail to apply.
*.patch -text

# Team files feed pack-team/validate-team and the panel_hash (a CONTENT hash of the
# .txt + .packed). CRLF rewriting on checkout would drift team_hash/panel_hash across
# platforms — keep them LF-stable.
showdown_bot/teams/** -text

# T4 smoke evidence: result rows, seed logs, manifests, gate/repro logs and diffs are
# byte-pinned by sha256.txt. CRLF rewriting would break those checksums — keep LF-stable.
# The divergent room logs are gzipped, so mark them binary (never touched by CRLF/diff).
data/eval/t4/** -text
data/eval/t4/room_raw_divergent/** binary
data/eval/t4/rerun/room_raw/** binary

# T6 held-out baseline evidence: results, seed logs, manifests, eval-report md/json,
# repro/spot-check logs are byte-pinned by sha256.txt — keep LF-stable so the checksums
# survive checkout on any platform. The gzipped room logs are binary (never CRLF/diff'd).
data/eval/t6/** -text
data/eval/t6/room_raw/** binary

# 2b-2.5a panel-diverse dataset: manifest.json, sha256.txt, and per-quarter evidence
# (result rows, seed logs, run manifests) are byte-pinned by sha256.txt — keep LF-stable so
# the checksums survive checkout on any platform. The merged dataset .gz is binary.
data/datasets/phase3-slice2b25a/** -text
data/datasets/phase3-slice2b25a/dataset.jsonl.gz binary

# 2b-4 gated-override evidence: determinism double-run results/manifests/seeds and the
# dev-strength paired-report results/manifests/seeds/report are byte-pinned by sha256.txt —
# keep LF-stable so the checksums survive checkout on any platform.
data/eval/2b4/** -text

# Champions evaluation evidence is byte-pinned; CRLF rewriting would break frozen hashes.
# Deliberately covers the whole panel dir, not just one smoke: the I5/I6/I7a evidence was
# already being rewritten to CRLF on Windows checkout (blob LF, working copy CRLF), so the
# sha256 values their reports pin could not be reproduced there. The I7b sidecar writes
# LF-only bytes by construction (eval/opp_mega_trace.py) — without this rule git would undo
# that on the next checkout, which is precisely the defect the sidecar's own byte tests exist
# to prevent.
data/eval/champions-panel-v0/** -text

# eval-report builds report.md as `"\n".join(out) + "\n"`, so a run whose last section ends
# on an empty line deterministically emits a trailing blank line. That is the generator's
# byte-exact output and is pinned by the report's sha256 — trimming it by hand would break
# reproducibility against a re-run. Silence the blank-at-eof lint instead of the bytes.
data/eval/champions-panel-v0/**/report.md whitespace=-blank-at-eof

# 05 generalisation golden: report.json/report.md are compared byte-for-byte by
# test_report_matches_golden. The reporting code writes LF (newline="\n"), so CRLF
# rewriting on checkout would break the comparison — keep them LF-stable.
showdown_bot/tests/generalisation/golden/** -text

# Pinned calc manifest is hashed byte-for-byte by calc_pin_hash(). core.autocrlf on
# Windows would rewrite checkout to CRLF and drift the pin hash — force LF.
showdown_bot/tools/calc/PINNED_CALC.json text eol=lf

# --- Provenance inputs hashed by RAW BYTES: force LF on index AND checkout ----------
#
# PINNED_CALC.json above had the right idea and the wrong scope. These files are read with
# `.read_bytes()` and hashed directly, so `core.autocrlf` made their digests -- and every
# hash derived from them -- PLATFORM-DEPENDENT. Measured, not assumed: the same Champions
# config hashes to 5fb04622afebd59f on Windows and b3cb6ea1a4836060 on Linux, purely
# because git checked the same blobs out with different line endings. That means two runs
# of an identical configuration on different hosts record different config_hash values, so
# any cross-platform A/B comparison silently compares "different" configs.
#
# The raw-byte hashers, and what each reads:
#   engine/calc/pin.py::format_config_hash  sha1(source_path.read_bytes())  -> config/formats/*.yaml
#   eval/config_env.py::file_content_hash   sha1(path.read_bytes())         -> meta priors/spreads, movedata.json
#   eval/report.py::_sha256_file            sha256(path.read_bytes())       -> report.json input_sha256: schedule, panel, ...
#   eval/baseline.py::_sha256_file          sha256(path.read_bytes())       -> panel yaml
# (engine/generated_data_hash.py::embedded_table_hash re-dumps PARSED json, so itemdata_hash
# and speciesdata_hash were already platform-stable and are not the reason for the drift.)
#
# `text eol=lf` rather than `-text` deliberately: `-text` only stops conversion, leaving
# whatever bytes are already on disk; `text eol=lf` normalises on ADD as well, so a CRLF
# working copy can never be committed back in and the index stays LF forever.
showdown_bot/config/**/*.yaml text eol=lf
showdown_bot/config/**/*.json text eol=lf
config/eval/**/*.yaml text eol=lf
config/eval/**/*.jsonl text eol=lf

# Frozen Studio mockup sources are recorded with byte-level SHA-256 provenance.
# Do not let platform checkout rules rewrite their line endings.
showdownbot_studio/docs/design/viewer-v0-mockups/*.html -text
showdownbot_studio/docs/design/viewer-v0-mockups/support.js -text
showdownbot_studio/docs/design/viewer-v0-mockups/thumbnail.webp binary

# Studio viewer-v0 fixtures are byte-pinned by manifest sha256 (bundle contract).
# Same class of defect as Champions config/hash drift: without an attribute, Windows
# core.autocrlf rewrites LF blobs to CRLF on checkout/merge and every raw-byte
# manifest check fails. Prefer `text eol=lf` (normalises on add AND checkout).
showdownbot_studio/fixtures/** text eol=lf
showdownbot_studio/godot/tests/fixtures/** text eol=lf

# Gate B Task 13 source-proof evidence freeze: sources.json pins a sha256 per teamlist .txt.
# text eol=lf (not -text), matching the provenance-inputs rationale above: this evidence was
# authored LF on write, but the pinned hashes must survive a checkout on any platform, and
# eol=lf also stops a CRLF working copy from ever being committed back in and drifting the
# index. Independent-source evidence has no weaker a claim to byte-stability than a fixture.
docs/projects/champions/audits/2026-07-21-task13-source-evidence/** text eol=lf
