.env
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
dist/
build/
.worktrees/
showdown_bot/logs/

# Calc bridge deps: a build artifact regenerated by `npm ci` (setup_calc_bridge). Tracking it
# partially (@smogon/calc src without dist/) made every fresh Kaggle clone dirty after npm ci,
# which fail-closes the eval-harness `dirty` safety gate on strength claims. node_modules is now
# ignored; npm ci rebuilds it from the committed package-lock.json, leaving the tree clean.
showdown_bot/tools/calc/node_modules/

# Datasets: raw JSONL is large + deterministically regenerable; keep the .gz + manifest.
data/datasets/**/*.jsonl
# 2b-2.5a evidence: small per-quarter result rows + seed logs are provenance (byte-pinned by
# sha256.txt), not the large regenerable merged dataset — keep them despite the rule above.
!data/datasets/phase3-slice2b25a/evidence/**/*.jsonl
